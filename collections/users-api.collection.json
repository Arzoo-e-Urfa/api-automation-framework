									"",
									"pm.test(\"Response has data object\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('data');",
									"    pm.expect(jsonData.data.id).to.eql(2);",
									"});"
								],
								"type": "text/javascript"
							}
						}
