{
	"info": {
		"_postman_id": "b1a7d6e4-44b4-4e4b-91c2-12f5a6b8c9d0",
		"name": "Users API Automation",
		"description": "API Automation Framework demonstrating modern QA practices including CRUD operations, Authentication, Negative Testing, and Schema Validation.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
