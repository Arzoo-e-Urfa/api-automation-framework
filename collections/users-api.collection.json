									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"User updated successfully\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.job).to.eql(\"zion resident\");",
									"    pm.expect(jsonData).to.have.property('updatedAt');",
									"});"
								],
